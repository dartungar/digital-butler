@inherits LayoutComponentBase

<div class="page app-shell">
    <div class="sidebar app-sidebar">
        <NavMenu/>
    </div>

    <main class="app-main">
        <div class="top-row app-topbar">
            <div class="topbar-copy">
                <span class="topbar-kicker">Private console</span>
                <span class="topbar-title">DigitalButler workspace</span>
            </div>
            <div class="topbar-status">
                <span class="status-dot"></span>
                <span>Online</span>
            </div>
        </div>

        <section class="section app-content">
            <div class="container app-container">
                @Body
            </div>
        </section>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
