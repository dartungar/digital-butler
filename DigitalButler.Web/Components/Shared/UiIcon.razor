<span class="@CssClass" aria-hidden="true">
    @switch (Name)
    {
        case "home":
            <svg viewBox="0 0 24 24" fill="none"><path d="M3 10.8 12 3l9 7.8v9.7a.5.5 0 0 1-.5.5h-5.2v-6.5H8.7V21H3.5a.5.5 0 0 1-.5-.5v-9.7Z" /></svg>
            break;
        case "database":
            <svg viewBox="0 0 24 24" fill="none"><path d="M4 6.5c0 1.9 3.6 3.5 8 3.5s8-1.6 8-3.5S16.4 3 12 3 4 4.6 4 6.5Z" /><path d="M4 6.5v5c0 1.9 3.6 3.5 8 3.5s8-1.6 8-3.5v-5" /><path d="M4 11.5v5c0 1.9 3.6 3.5 8 3.5s8-1.6 8-3.5v-5" /></svg>
            break;
        case "sync":
            <svg viewBox="0 0 24 24" fill="none"><path d="M20 7h-9a5 5 0 0 0-4.7 3.3" /><path d="m17 4 3 3-3 3" /><path d="M4 17h9a5 5 0 0 0 4.7-3.3" /><path d="m7 20-3-3 3-3" /></svg>
            break;
        case "note":
            <svg viewBox="0 0 24 24" fill="none"><path d="M6 3h8l4 4v14H6V3Z" /><path d="M14 3v5h4" /><path d="M9 12h6" /><path d="M9 16h6" /></svg>
            break;
        case "search":
            <svg viewBox="0 0 24 24" fill="none"><circle cx="10.8" cy="10.8" r="6.8" /><path d="m16 16 5 5" /></svg>
            break;
        case "calendar":
            <svg viewBox="0 0 24 24" fill="none"><path d="M5 5h14v16H5V5Z" /><path d="M8 3v4" /><path d="M16 3v4" /><path d="M5 10h14" /></svg>
            break;
        case "sun":
            <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="4" /><path d="M12 2v2" /><path d="M12 20v2" /><path d="m4.9 4.9 1.4 1.4" /><path d="m17.7 17.7 1.4 1.4" /><path d="M2 12h2" /><path d="M20 12h2" /><path d="m4.9 19.1 1.4-1.4" /><path d="m17.7 6.3 1.4-1.4" /></svg>
            break;
        case "moon":
            <svg viewBox="0 0 24 24" fill="none"><path d="M20.2 14.3A7.8 7.8 0 0 1 9.7 3.8 8.5 8.5 0 1 0 20.2 14.3Z" /></svg>
            break;
        case "monitor":
            <svg viewBox="0 0 24 24" fill="none"><path d="M4 5h16v11H4V5Z" /><path d="M8 20h8" /><path d="M12 16v4" /></svg>
            break;
        case "chevron-left":
            <svg viewBox="0 0 24 24" fill="none"><path d="m15 6-6 6 6 6" /></svg>
            break;
        case "chevron-right":
            <svg viewBox="0 0 24 24" fill="none"><path d="m9 6 6 6-6 6" /></svg>
            break;
        case "mail":
            <svg viewBox="0 0 24 24" fill="none"><path d="M4 6h16v12H4V6Z" /><path d="m4 7 8 6 8-6" /></svg>
            break;
        case "spark":
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3Z" /><path d="m18 15 .8 2.2L21 18l-2.2.8L18 21l-.8-2.2L15 18l2.2-.8L18 15Z" /></svg>
            break;
        case "activity":
            <svg viewBox="0 0 24 24" fill="none"><path d="M4 13h4l2-7 4 12 2-5h4" /></svg>
            break;
        case "plus-note":
            <svg viewBox="0 0 24 24" fill="none"><path d="M6 3h8l4 4v14H6V3Z" /><path d="M14 3v5h4" /><path d="M9 15h6" /><path d="M12 12v6" /></svg>
            break;
        case "settings":
            <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" /><path d="M19 12a7.7 7.7 0 0 0-.1-1l2-1.6-2-3.5-2.4 1a8.8 8.8 0 0 0-1.7-1L14.5 3h-5l-.4 2.8a8.8 8.8 0 0 0-1.7 1l-2.4-1-2 3.5 2 1.6a7.7 7.7 0 0 0 0 2l-2 1.6 2 3.5 2.4-1a8.8 8.8 0 0 0 1.7 1l.4 2.8h5l.4-2.8a8.8 8.8 0 0 0 1.7-1l2.4 1 2-3.5-2-1.6c.1-.3.1-.7.1-1Z" /></svg>
            break;
        case "trash":
            <svg viewBox="0 0 24 24" fill="none"><path d="M5 7h14" /><path d="M10 11v6" /><path d="M14 11v6" /><path d="M7 7l1 14h8l1-14" /><path d="M9 7V4h6v3" /></svg>
            break;
        case "edit":
            <svg viewBox="0 0 24 24" fill="none"><path d="m4 16.5-.8 4.3 4.3-.8L19 8.5 15.5 5 4 16.5Z" /><path d="m14.5 6 3.5 3.5" /></svg>
            break;
        case "play":
            <svg viewBox="0 0 24 24" fill="none"><path d="M8 5v14l11-7L8 5Z" /></svg>
            break;
        default:
            <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" /><path d="M12 8v4" /><path d="M12 16h.01" /></svg>
            break;
    }
</span>

@code {
    [Parameter]
    public string Name { get; set; } = "info";

    [Parameter]
    public string Class { get; set; } = string.Empty;

    private string CssClass => string.IsNullOrWhiteSpace(Class) ? "db-icon" : $"db-icon {Class}";
}
